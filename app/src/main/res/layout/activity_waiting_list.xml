<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8E0E0"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvWaitingListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registered Entrants"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvEntrantCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Entrants: 0"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRunLottery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Run Lottery"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEntrants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <Button
        android:id="@+id/btnMessageWaiting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Message Waiting List" />

</LinearLayout>