<?xml version="1.0" encoding="utf-8"?>
<!--
    US 02.02.01 + US 02.06.05
    Waiting List screen showing registered entrants with CSV export button.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8E0E0"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvWaitingListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registered Entrants"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Total entrant count -->
    <TextView
        android:id="@+id/tvEntrantCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Entrants: 0"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginBottom="12dp" />

    <!-- Entrant list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEntrants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <!-- Export CSV button (US 02.06.05) -->
    <Button
        android:id="@+id/btnExportCsv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Export users as CSV"
        android:backgroundTint="#4A90D9"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

</LinearLayout>