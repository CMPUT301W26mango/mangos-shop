<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardUseCompatPadding="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/commentingUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/isOrganizerTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organizer"
                    android:background="@android:color/darker_gray"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/commentTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#999999"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/commentContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#444444"
                android:textSize="15sp"
                app:layout_constraintTop_toBottomOf="@id/headerLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />



        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/replyIndicatorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:textColor="@color/blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </androidx.cardview.widget.CardView>



    <androidx.cardview.widget.CardView
        android:id="@+id/reactionTallyCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="-2dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="5dp">

        <TextView
            android:id="@+id/reactionTallyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="7dp"
            android:paddingBottom="8dp"
            android:textColor="#555555"
            android:textSize="16sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/reactionPopupCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/reactionChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            app:singleSelection="true"
            app:chipSpacingHorizontal="4dp"
            app:chipSpacingVertical="4dp"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipThumbsUp"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👍"
                android:textColor="@color/chip_text_state"
                app:chipMinHeight="26dp"
                android:textSize="12sp"
                app:chipBackgroundColor="@color/chip_background_state" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipHeart"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❤️"
                android:textColor="@color/chip_text_state"
                app:chipMinHeight="32dp"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background_state" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipLaugh"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😂"
                android:textColor="@color/chip_text_state"
                app:chipMinHeight="32dp"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background_state" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipThumbsDown"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👎"
                android:textColor="@color/chip_text_state"
                app:chipMinHeight="32dp"
                android:textSize="14sp"
                app:chipBackgroundColor="@color/chip_background_state" />

        </com.google.android.material.chip.ChipGroup>
    </androidx.cardview.widget.CardView>

</FrameLayout>