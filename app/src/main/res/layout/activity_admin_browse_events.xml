<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    tools:context=".AdminBrowseEventsActivity">

    <TextView
        android:id="@+id/textViewAdminHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Admin Browse Events"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="12dp" />

    <SearchView
        android:id="@+id/searchViewEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DDDDDD"
        android:queryHint="Search events" />

    <TextView
        android:id="@+id/textViewEmptyEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="No events found"
        android:textColor="#000000"
        android:textAlignment="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAdminEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1" />

</LinearLayout>